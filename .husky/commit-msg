COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# feat: New functionality (feature) in the code
# fix: Bug fix
# refactor: Refactoring without changing behavior
# chore: Changes to the project that do not affect the code (e.g. scripts, configurations)
# docs: Documentation changes (README, comments, etc.)
# style: Formatting adjustments (spaces, indentation, semicolons)
# test: Adição ou ajuste de testes
# perf: Performance improvements
# ci: Changes to CI/CD configurations (GitHub Actions, etc.)
# build: Changes affecting project build (compilation, dependencies)

if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|refactor|chore|docs|style|test|perf|ci|build): '; then
  echo "❌ Error: The commit message is invalid."
  echo "Check the accepted types in the .husky/commit-msg file"
  exit 1
fi

exit 0
